# --- DataForSEO (required) ---------------------------------------------------
# Create at https://app.dataforseo.com/api-access — these are your API
# credentials (NOT your dashboard email/password unless they match).
DATAFORSEO_LOGIN=your-login@example.com
DATAFORSEO_PASSWORD=your-api-password

# --- Claude (optional) -------------------------------------------------------
# Without this, agents fall back to deterministic analysis (no LLM reasoning,
# no AI-written content briefs). With it, Agent 3 writes real briefs.
ANTHROPIC_API_KEY=
AUTOSEO_MODEL=claude-sonnet-4-6

# --- Tuning (optional) -------------------------------------------------------
DATAFORSEO_MAX_CONCURRENCY=5     # parallel in-flight API calls
DATAFORSEO_TIMEOUT=120           # per-request timeout (seconds)
DATAFORSEO_DAILY_BUDGET=5.0      # hard stop in USD; client aborts past this
AUTOSEO_CACHE_DIR=caches         # where rank history is persisted between runs
