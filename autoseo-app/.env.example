# --- Required for Claude features ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Models. Separate from auditor solver so they can be tuned independently.
# AUTOSEO_MODEL=claude-sonnet-4-6              # used by the auditor solver
# AUTOSEO_AGENT_MODEL=claude-sonnet-4-6        # used by the Phase 1 agents

# --- Phase 1 agent system -------------------------------------------------
DAILY_LLM_SPEND_CAP_USD=5        # hard stop across all agent LLM calls
# AGENT_DRY_RUN=1                # run agents + persist proposals, skip notifications

# Competitor crawling. With Firecrawl: clean markdown. Without: fetch + cheerio fallback.
# FIRECRAWL_API_KEY=fc-...

# WhatsApp digests via Interakt. Without these the system logs digests to console.
# Verify your template name + variable count in the Interakt console; the template
# referenced needs two body variables: {{1}} = body text, {{2}} = dashboard link.
# INTERAKT_API_KEY=
# INTERAKT_PHONE_NUMBER=+919876543210
# INTERAKT_TEMPLATE_NAME=agent_digest
# INTERAKT_LANG=en

# Disable the agent cron scheduler (useful for one-off CLI runs / tests).
# AUTOSEO_DISABLE_AGENT_SCHEDULER=1
# AUTOSEO_DISABLE_WEB_SEARCH=1   # if your Anthropic tier doesn't have web search

# --- Existing always-on mode (already in use) ----------------------------
# PORT=3000
# AUTOSEO_PUBLIC_ENDPOINT=http://localhost:3000
# AUTOSEO_DATA_DIR=data
# AUTOSEO_FIXES_ROOT=
