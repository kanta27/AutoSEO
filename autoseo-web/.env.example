# --- Supabase -------------------------------------------------------------
# Get these from https://app.supabase.com → your project → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- MeshAPI (OpenAI-compatible gateway — server-only, never ship to browser) ---
# Get your key at https://app.meshapi.ai/
MESHAPI_API_KEY=
# Override only if MeshAPI changes their endpoint. Default works as-is.
MESHAPI_BASE_URL=https://api.meshapi.ai/v1
# The exact model slug as shown in your MeshAPI dashboard. Default is the
# best-inference Kimi 2.5 slug; replace if MeshAPI shows a different one.
AUTOSEO_MODEL=moonshotai/Kimi-K2.5

# --- Node SEO engine (autoseo-app) ----------------------------------------
# Default 3000. The Next app defaults to 3001 so there's no port collision.
NODE_ENGINE_URL=http://localhost:3000
NODE_ENGINE_TIMEOUT_MS=30000
