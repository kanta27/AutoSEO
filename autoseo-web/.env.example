# --- Supabase -------------------------------------------------------------
# Get these from https://app.supabase.com → your project → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (OpenAI-compatible endpoint — server-only, never commit) ---
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Override only if Google changes the compat endpoint. Default works as-is —
# note the TRAILING SLASH, required for OpenAI SDK path resolution.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# gemini-2.5-flash has the AI Studio free tier; gemini-3.5-flash is the newer
# paid GA (released 2026-05-19, $1.50 in / $9.00 out per 1M tokens).
AUTOSEO_MODEL=gemini-2.5-flash

# --- Node SEO engine (autoseo-app) ----------------------------------------
# Default 3000. The Next app defaults to 3001 so there's no port collision.
NODE_ENGINE_URL=http://localhost:3000
NODE_ENGINE_TIMEOUT_MS=30000

# --- Scheduler ------------------------------------------------------------
# Any random string. The cron-facing POST /api/scheduler/run requires it as
# `x-scheduler-secret` so the public can't trigger paid engine work.
# Generate one: `openssl rand -hex 32` (or any password generator).
SCHEDULER_SECRET=

# Set to "true" to run the in-process tick. Useful for dev / a long-running
# VM; in serverless deployments leave it OFF and point an external cron at
# /api/scheduler/run. Off by default to avoid surprise engine spend.
ENABLE_LOCAL_SCHEDULER=false
# How often the local tick CHECKS for due agents. The actual agent runs still
# respect each agent's schedule_hours (default 24h).
LOCAL_SCHEDULER_INTERVAL_MINUTES=15
