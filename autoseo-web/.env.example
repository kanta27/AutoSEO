# --- Supabase -------------------------------------------------------------
# Get these from https://app.supabase.com → your project → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM provider (Groq, via OpenAI-compatible endpoint) -----------------
# Previously Google Gemini; switched 2026-05 because Gemini's free-tier
# compat layer silently 400s on tool-calling requests. If a future provider
# swap is needed, `lib/llm.ts` is the single place to do it — every caller
# goes through the exports there.
GROQ_API_KEY=                                       # get one at https://console.groq.com (free, no credit card)
AUTOSEO_MODEL=llama-3.3-70b-versatile               # Groq's flagship; supports tool calling
# GROQ_BASE_URL=https://api.groq.com/openai/v1      # only set to override the default

# --- Node SEO engine (autoseo-app) ----------------------------------------
# Default 3000. The Next app defaults to 3001 so there's no port collision.
#
# Prefer `localhost` over `127.0.0.1`. On Windows + Node 18+, the two can
# resolve through different stacks (IPv6 vs IPv4) and one form may be
# unreachable even when the engine is up. The web app falls back to the
# other loopback form automatically on a connection error, so either works —
# but `localhost` is the more reliable default.
NODE_ENGINE_URL=http://localhost:3000
NODE_ENGINE_TIMEOUT_MS=30000

# --- Publishing connectors (server-only) ----------------------------------
# Companies are auto-detected at onboarding (companies.platform). The
# approval handler dispatches blog_post publishes to the matching connector
# below. Companies on an unknown platform fall back to a "Copy markdown"
# manual flow in the UI — no publish call.
#
# Single-site for now. The true multi-tenant version moves these into
# per-company settings (lib/connectors/index.ts → getPublisher will read
# from the company row instead of env).

# Shopify (companies.platform = 'shopify')
# From Shopify Admin → Apps → Develop apps → custom app → Admin API access token.
# Required scopes: write_content (to create blog articles), read_content.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=
# Optional: target a specific blog. If unset, the connector picks the first
# blog returned by GET /admin/api/2026-01/blogs.json.
SHOPIFY_BLOG_ID=

# WordPress (companies.platform = 'wordpress')
# Generate an Application Password (WP 5.6+, no plugin needed) at:
#   wp-admin → Users → Edit User → Application Passwords
# Application Passwords are separate from the login password and can be
# revoked without changing it.
WORDPRESS_SITE_URL=https://example.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# --- Blog publish routing -------------------------------------------------
# Where the Coding Agent commits markdown for blog-handoff PRs (the third
# blog publish path, for sites not on Shopify/WordPress). The agent writes
# `${BLOG_REPO_FOLDER}/{slug}.md` on a feature branch and opens a PR.
BLOG_REPO_FOLDER=content/blog

# Set to "true" to make blog approval go through the legacy CMS connector
# (Shopify/WordPress) when the company's platform is one of those. Default
# (false) routes EVERY blog approval through the Coding Agent's markdown-PR
# path — matches the "first check things work with human permission" model
# (two consent gates: approve draft → approve PR).
BLOG_PUBLISH_VIA_CMS=false

# --- GitHub (single-tenant / single-repo for now; PR-based, never main) ---
# The SEO-fix / GEO-fix / Coding agents propose file edits as Pull Requests.
# Approval in the dashboard opens a PR on the repo below — the connector
# NEVER pushes to a default/protected branch and NEVER auto-merges.
#
# Generate a Personal Access Token at:
#   github.com → Settings → Developer settings → Personal access tokens
# Required scopes: `repo` for private repos, OR `public_repo` for public-only.
# Revoke a token any time from the same page.
#
# Future multi-tenant: per-user GitHub App + OAuth replaces these env vars —
# tokens move to companies.platform_meta. The connector signature already
# takes `company` so call sites don't change.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# --- Marketing skills (vendored, see ../skills/README.md) -----------------
# When true (default), the Blog + Coding agents inject curated framework
# markdown into their system prompts (~10-12k tokens of reference context
# per agent run). Set to "false" to disable — useful for A/B comparing
# output quality with vs. without, or for clamping LLM context cost.
SKILLS_ENABLED=true

# --- Google PageSpeed Insights (optional) ---------------------------------
# The dashboard's PageSpeed panel calls Google's free PSI v5 API for the
# company's root URL (Mobile + Desktop, ~15-30s per call). The endpoint
# works WITHOUT a key for low volume, but the public quota is 25k/day and
# 4 QPS. Set a key for higher limits.
# Get one at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# --- Tavily web search (optional — blog agent uses it for freshness) ------
# Get a key at https://tavily.com (free tier available). If unset, the blog
# agent skips external research and writes from on-site context only.
# As of the world-aware blog update, this key powers THREE blog-agent tools:
#   • web_search                       — generic search for supporting facts
#   • get_news_for_topic               — Tavily news mode (last 14 days)
#   • get_trending_topics_for_industry — "latest trends {category}" query
# Each tool degrades to `{ available: false }` when the key is unset; the
# agent still produces a draft, just without external signal.
TAVILY_API_KEY=

# --- Scheduler ------------------------------------------------------------
# Any random string. The cron-facing POST /api/scheduler/run requires it as
# `x-scheduler-secret` so the public can't trigger paid engine work.
# Generate one: `openssl rand -hex 32` (or any password generator).
SCHEDULER_SECRET=

# Set to "true" to run the in-process tick. Useful for dev / a long-running
# VM; in serverless deployments leave it OFF and point an external cron at
# /api/scheduler/run. Off by default to avoid surprise engine spend.
ENABLE_LOCAL_SCHEDULER=false
# How often the local tick CHECKS for due agents. The actual agent runs still
# respect each agent's schedule_hours (default 24h).
LOCAL_SCHEDULER_INTERVAL_MINUTES=15
